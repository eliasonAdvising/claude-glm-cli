#!/usr/bin/env bash
# glm-subagent
#
# Portable GLM-backed Claude Code subprocess wrapper.
#
# Reads a task prompt on stdin and emits the subprocess's final text on stdout.
# Used by the parent Claude session to delegate bounded execution tasks to GLM.
# This wrapper is project-agnostic and can be installed globally at ~/.local/bin/glm-subagent.
#
# FEATURES:
#   F1 - Usage telemetry: logs each dispatch to ~/.local/share/glm/usage.jsonl
#        v0.2 — real token + duration + cost data via --output-format json
#   F2 - Layered system prompt: loads .claude/glm-conventions.md from current project if present
#
# NOTE on cost: the claude CLI emits `total_cost_usd` in its JSON output, but
# it's computed at Anthropic Claude rates, not Z.AI GLM rates. We capture it
# as `cli_cost_usd_claude_rate` for reference, and store the raw token counts
# so `glm-usage` can compute real $ cost using GLM-4.6 pricing.
#
# The subprocess inherits the parent process's working directory, the user's
# ~/.claude/settings.json (allow-listed tools), and the project's local skills.
# Permission prompts are bypassed (--dangerously-skip-permissions) because there
# is no interactive user to answer them; scope is enforced by:
#   (1) --allowed-tools allowlist below (harness-level, not prompt-level), and
#   (2) the packet's Constraints / Do not change / Stop conditions.
#
# Env vars:
#   GLM_API_KEY        required — Z.AI bearer token (or use ~/.glm-key)
#   GLM_MODEL          optional — default: glm-4.6
#   GLM_SMALL_MODEL    optional — default: glm-4.5-air
#   GLM_ENDPOINT       optional — default: https://api.z.ai/api/anthropic
#
# Exit codes:
#   0    success
#   1    general error
#   64   GLM_API_KEY missing
#   65   empty prompt on stdin
#   66   bad permissions on ~/.glm-key
#   *    pass-through from claude subprocess

set -euo pipefail

VERSION="v0.2.0"

# -----------------------------------------------------------------------------
# --version / --help
# -----------------------------------------------------------------------------

if [[ "${1:-}" == "--version" ]]; then
  echo "glm-cli $VERSION"
  exit 0
fi

if [[ "${1:-}" == "--help" ]]; then
  cat <<'EOF'
glm-subagent - Portable GLM-backed Claude Code subprocess wrapper

USAGE:
  echo "<task_packet>" | glm-subagent
  glm-subagent --version
  glm-subagent --help

ENVIRONMENT VARIABLES:
  GLM_API_KEY        Z.AI bearer token (or use ~/.glm-key)
  GLM_MODEL          Model to use (default: glm-4.6)
  GLM_SMALL_MODEL    Small/fast model (default: glm-4.5-air)
  GLM_ENDPOINT       API endpoint (default: https://api.z.ai/api/anthropic)

EXIT CODES:
  0    success
  1    general error
  64   GLM_API_KEY missing
  65   empty prompt on stdin
  66   bad permissions on ~/.glm-key

FEATURES:
  F1 - Telemetry logged to ~/.local/share/glm/usage.jsonl
       v0.2 captures real token + cost + duration from claude --output-format json
  F2 - Loads .claude/glm-conventions.md from current project if present
EOF
  exit 0
fi

# -----------------------------------------------------------------------------
# Resolve GLM_API_KEY
# -----------------------------------------------------------------------------

# Prefer env var (e.g. exported in ~/.bashrc), fall back to ~/.glm-key (chmod 600)
if [[ -z "${GLM_API_KEY:-}" ]] && [[ -r "$HOME/.glm-key" ]]; then
  # Strict permission check: refuse if the file is group/world readable
  PERMS="$(stat -c '%a' "$HOME/.glm-key" 2>/dev/null || stat -f '%Lp' "$HOME/.glm-key")"
  if [[ "$PERMS" != "600" && "$PERMS" != "400" ]]; then
    echo "error: ~/.glm-key has perms $PERMS; run 'chmod 600 ~/.glm-key'" >&2
    exit 66
  fi
  GLM_API_KEY="$(head -n1 "$HOME/.glm-key" | tr -d '[:space:]')"
fi

if [[ -z "${GLM_API_KEY:-}" ]]; then
  echo "error: GLM_API_KEY not set and ~/.glm-key not present" >&2
  exit 64
fi

# -----------------------------------------------------------------------------
# Read prompt from stdin
# -----------------------------------------------------------------------------

PROMPT="$(cat)"
if [[ -z "${PROMPT// /}" ]]; then
  echo "error: empty prompt on stdin" >&2
  exit 65
fi

# -----------------------------------------------------------------------------
# F2 - Layered system prompt (load conventions from current project)
# -----------------------------------------------------------------------------

# Base universal system prompt
BASE_SYSTEM_PROMPT="You are GLM, a focused executor. Output exactly what the task packet asks for. No narration, no opinions, no scope creep. Prefer minimal changes."

CONVENTIONS_FILE="$PWD/.claude/glm-conventions.md"
SYSTEM_PROMPT="$BASE_SYSTEM_PROMPT"

if [[ -r "$CONVENTIONS_FILE" ]]; then
  CONVENTIONS_CONTENT="$(cat "$CONVENTIONS_FILE")"
  CONVENTIONS_LEN="${#CONVENTIONS_CONTENT}"

  # Warn if conventions file is excessively long
  if [[ $CONVENTIONS_LEN -gt 4000 ]]; then
    echo "warn: conventions file is $CONVENTIONS_LEN chars; consider trimming" >&2
  fi

  # Append conventions to base system prompt
  SYSTEM_PROMPT="$BASE_SYSTEM_PROMPT

## Project conventions

$CONVENTIONS_CONTENT"
fi

# -----------------------------------------------------------------------------
# Prepare telemetry (F1)
# -----------------------------------------------------------------------------

DISPATCH_UUID="$(cat /proc/sys/kernel/random/uuid 2>/dev/null || echo "unknown-$(date +%s%N)")"
START_EPOCH_MS="$(date +%s%3N)"  # milliseconds since epoch
PACKET_BYTES="${#PROMPT}"
CWD="$PWD"
MODEL="${GLM_MODEL:-glm-4.6}"
LOG_FILE="$HOME/.local/share/glm/usage.jsonl"

# Ensure log directory exists
mkdir -p "$(dirname "$LOG_FILE")" 2>/dev/null || true

# -----------------------------------------------------------------------------
# Allowed tools allowlist (same as ffusa-site wrapper)
# -----------------------------------------------------------------------------

ALLOWED_TOOLS="Read,Edit,Write,Glob,Grep,\
Bash(npm:*),Bash(npx:*),Bash(node:*),\
Bash(git status),Bash(git diff:*),Bash(git log:*),Bash(git show:*),\
Bash(git ls-files:*),Bash(git rev-parse:*),Bash(git blame:*),\
Bash(ls:*),Bash(cat:*),Bash(pwd:*),Bash(echo:*),Bash(test:*),\
Bash(grep:*),Bash(find:*),Bash(head:*),Bash(tail:*),Bash(wc:*)"

# -----------------------------------------------------------------------------
# Invoke claude subprocess (v0.2: --output-format json captures full usage)
# -----------------------------------------------------------------------------

# Capture the JSON response. Disable `set -e` for this block so we can read
# claude's exit code even on non-zero (e.g. is_error=true scenarios).
set +e
RAW_RESPONSE="$(printf '%s' "$PROMPT" | env \
  ANTHROPIC_BASE_URL="${GLM_ENDPOINT:-https://api.z.ai/api/anthropic}" \
  ANTHROPIC_AUTH_TOKEN="$GLM_API_KEY" \
  ANTHROPIC_MODEL="${GLM_MODEL:-glm-4.6}" \
  ANTHROPIC_SMALL_FAST_MODEL="${GLM_SMALL_MODEL:-glm-4.5-air}" \
  claude --print \
         --dangerously-skip-permissions \
         --output-format json \
         --allowed-tools "$ALLOWED_TOOLS" \
         --append-system-prompt "$SYSTEM_PROMPT")"
CLAUDE_EXIT_CODE=$?
set -e

# -----------------------------------------------------------------------------
# Parse the JSON response — extract `.result` for stdout, `.usage.*` for telemetry
# -----------------------------------------------------------------------------

END_EPOCH_MS="$(date +%s%3N)"
WALL_CLOCK_MS=$((END_EPOCH_MS - START_EPOCH_MS))

# Verify the response is parseable JSON. If not, fall back to passing raw
# through (older claude CLI versions, malformed output, network errors).
if printf '%s' "$RAW_RESPONSE" | jq -e . >/dev/null 2>&1; then
  RESULT="$(printf '%s' "$RAW_RESPONSE" | jq -r '.result // empty')"
  IS_ERROR="$(printf '%s' "$RAW_RESPONSE" | jq -r '.is_error // false')"
  # If claude reported is_error and the subprocess exited 0 (e.g. API returned
  # an error JSON that the CLI surfaces but doesn't translate to exit code),
  # promote it to exit 1 so callers can detect.
  if [[ "$IS_ERROR" == "true" && "$CLAUDE_EXIT_CODE" == "0" ]]; then
    CLAUDE_EXIT_CODE=1
  fi
  RESPONSE_FOR_STDOUT="$RESULT"
  RESPONSE_BYTES="${#RESULT}"

  # Extract telemetry fields (default null when missing)
  PROMPT_TOKENS="$(printf '%s' "$RAW_RESPONSE" | jq -r '.usage.input_tokens // "null"')"
  COMPLETION_TOKENS="$(printf '%s' "$RAW_RESPONSE" | jq -r '.usage.output_tokens // "null"')"
  CACHE_CREATION_TOKENS="$(printf '%s' "$RAW_RESPONSE" | jq -r '.usage.cache_creation_input_tokens // "null"')"
  CACHE_READ_TOKENS="$(printf '%s' "$RAW_RESPONSE" | jq -r '.usage.cache_read_input_tokens // "null"')"
  CLI_COST_USD="$(printf '%s' "$RAW_RESPONSE" | jq -r '.total_cost_usd // "null"')"
  NUM_TURNS="$(printf '%s' "$RAW_RESPONSE" | jq -r '.num_turns // "null"')"
  CLI_DURATION_MS="$(printf '%s' "$RAW_RESPONSE" | jq -r '.duration_ms // "null"')"
  CLI_DURATION_API_MS="$(printf '%s' "$RAW_RESPONSE" | jq -r '.duration_api_ms // "null"')"
  SESSION_ID="$(printf '%s' "$RAW_RESPONSE" | jq -r '.session_id // "null"')"

  # Compute total_tokens locally (input + output; excludes cache reads which
  # are billed separately at a different rate).
  if [[ "$PROMPT_TOKENS" != "null" && "$COMPLETION_TOKENS" != "null" ]]; then
    TOTAL_TOKENS=$((PROMPT_TOKENS + COMPLETION_TOKENS))
  else
    TOTAL_TOKENS="null"
  fi
else
  # JSON parsing failed — fall back to raw passthrough, log nulls for the
  # new fields so the JSONL stays schema-stable.
  RESPONSE_FOR_STDOUT="$RAW_RESPONSE"
  RESPONSE_BYTES="${#RAW_RESPONSE}"
  PROMPT_TOKENS="null"
  COMPLETION_TOKENS="null"
  CACHE_CREATION_TOKENS="null"
  CACHE_READ_TOKENS="null"
  CLI_COST_USD="null"
  NUM_TURNS="null"
  CLI_DURATION_MS="null"
  CLI_DURATION_API_MS="null"
  SESSION_ID="null"
  TOTAL_TOKENS="null"
fi

# -----------------------------------------------------------------------------
# F1 - Write telemetry (non-blocking)
# -----------------------------------------------------------------------------

# Build telemetry entry as JSON line. v0.2 schema adds:
# prompt_tokens, completion_tokens, total_tokens (sum of in+out),
# cache_creation_tokens, cache_read_tokens, cli_cost_usd_claude_rate
# (reference only — uses Anthropic Claude rates, not GLM rates),
# num_turns, cli_duration_ms, cli_duration_api_ms, session_id.
TELEMETRY_ENTRY="$(jq -nc \
  --arg ts "$(date -Iseconds)" \
  --arg uuid "$DISPATCH_UUID" \
  --arg cwd "$CWD" \
  --arg model "$MODEL" \
  --arg session_id "$SESSION_ID" \
  --argjson packet_bytes "$PACKET_BYTES" \
  --argjson response_bytes "$RESPONSE_BYTES" \
  --argjson wall_clock_ms "$WALL_CLOCK_MS" \
  --argjson exit_code "$CLAUDE_EXIT_CODE" \
  --argjson prompt_tokens "$PROMPT_TOKENS" \
  --argjson completion_tokens "$COMPLETION_TOKENS" \
  --argjson total_tokens "$TOTAL_TOKENS" \
  --argjson cache_creation_tokens "$CACHE_CREATION_TOKENS" \
  --argjson cache_read_tokens "$CACHE_READ_TOKENS" \
  --argjson cli_cost_usd_claude_rate "$CLI_COST_USD" \
  --argjson num_turns "$NUM_TURNS" \
  --argjson cli_duration_ms "$CLI_DURATION_MS" \
  --argjson cli_duration_api_ms "$CLI_DURATION_API_MS" \
  '{
    ts: $ts,
    uuid: $uuid,
    session_id: (if $session_id == "null" then null else $session_id end),
    cwd: $cwd,
    model: $model,
    packet_bytes: $packet_bytes,
    response_bytes: $response_bytes,
    wall_clock_ms: $wall_clock_ms,
    cli_duration_ms: $cli_duration_ms,
    cli_duration_api_ms: $cli_duration_api_ms,
    exit_code: $exit_code,
    num_turns: $num_turns,
    prompt_tokens: $prompt_tokens,
    completion_tokens: $completion_tokens,
    total_tokens: $total_tokens,
    cache_creation_tokens: $cache_creation_tokens,
    cache_read_tokens: $cache_read_tokens,
    cli_cost_usd_claude_rate: $cli_cost_usd_claude_rate
  }' 2>/dev/null)"

# Append to log file (silently fail if write fails)
if [[ -n "${TELEMETRY_ENTRY:-}" ]]; then
  echo "$TELEMETRY_ENTRY" >> "$LOG_FILE" 2>/dev/null || true
fi

# -----------------------------------------------------------------------------
# Emit response and exit
# -----------------------------------------------------------------------------

printf '%s' "$RESPONSE_FOR_STDOUT"
exit "$CLAUDE_EXIT_CODE"
