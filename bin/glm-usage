#!/usr/bin/env bash
set -euo pipefail

VERSION="v0.1.0-dev"

[[ "${1:-}" == "--version" ]] && echo "glm-usage $VERSION" && exit 0
[[ "${1:-}" == "--help" ]] && echo "Usage: glm-usage [--last Nd] [--format json|csv]" && exit 0

LAST_WINDOW="7d"
FORMAT="text"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --last) LAST_WINDOW="$2"; shift 2 ;;
    --format) FORMAT="$2"; shift 2 ;;
    *) echo "error: unknown option: $1" >&2; exit 1 ;;
  esac
done

LOG_FILE="$HOME/.local/share/glm/usage.jsonl"

[[ ! -f "$LOG_FILE" ]] && echo "No telemetry yet — fire a glm-subagent dispatch to generate data." && exit 0

if [[ "$FORMAT" == "json" ]]; then
  cat "$LOG_FILE"
elif [[ "$FORMAT" == "csv" ]]; then
  echo "CSV format not yet implemented"
else
  COUNT=$(wc -l < "$LOG_FILE" 2>/dev/null || echo "0")
  echo "Last ${LAST_WINDOW}: ${COUNT} entries in log"
fi

exit 0
