#!/usr/bin/env bash
# glm-usage — query GLM dispatch telemetry
#
# v0.2 adds: real GLM-rate $ cost computation from captured token counts.
# Backward-compatible with v0.1 telemetry entries (where token fields are null).

set -euo pipefail

VERSION="v0.2.0"
LOG_FILE="$HOME/.local/share/glm/usage.jsonl"

# GLM-4.6 pricing per Z.AI public list (as of 2026-06). Update if Z.AI changes rates.
# Cache pricing for GLM is not yet public; we use a conservative 25% of input rate
# for cache reads (Anthropic Sonnet pattern). Mark estimates as approximate.
GLM_INPUT_USD_PER_M="0.60"
GLM_OUTPUT_USD_PER_M="2.20"
GLM_CACHE_READ_USD_PER_M="0.15"   # ≈ 25% of input rate (estimate)
GLM_CACHE_WRITE_USD_PER_M="0.75"  # ≈ 1.25× input rate (estimate)

LAST_WINDOW="7d"
SINCE_ISO=""
CWD_FILTER=""
FORMAT="text"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --version) echo "glm-usage $VERSION"; exit 0 ;;
    --help|-h)
      cat <<HELP
glm-usage — query GLM dispatch telemetry from ~/.local/share/glm/usage.jsonl

USAGE:
  glm-usage [--last 7d|24h|...] [--since ISO_DATE] [--cwd SUBSTR] [--format text|json|csv|table|cost]

OPTIONS:
  --last NWINDOW    Time window (e.g. 24h, 7d, 30d). Default: 7d.
  --since ISO_DATE  Start date (overrides --last). Example: 2026-06-19T00:00:00Z
  --cwd SUBSTR      Filter by cwd substring.
  --format FMT      text (default), json, csv, table (per-cwd), cost (per-cwd \$ breakdown).
  --version         Print version.
  --help            This message.

PRICING (GLM-4.6 list, hardcoded; update in source if Z.AI changes):
  input:        \$${GLM_INPUT_USD_PER_M}/M tokens
  output:       \$${GLM_OUTPUT_USD_PER_M}/M tokens
  cache read:   \$${GLM_CACHE_READ_USD_PER_M}/M tokens (≈ 25% of input — estimate)
  cache write:  \$${GLM_CACHE_WRITE_USD_PER_M}/M tokens (≈ 1.25× input — estimate)

Note: cli_cost_usd_claude_rate in telemetry is what the claude CLI computed at
ANTHROPIC rates — included for reference but not the real GLM cost.

EXIT CODES:
  0    success (or no log yet)
  64   bad argument
HELP
      exit 0
      ;;
    --last) LAST_WINDOW="${2:-}"; shift 2 ;;
    --since) SINCE_ISO="${2:-}"; shift 2 ;;
    --cwd) CWD_FILTER="${2:-}"; shift 2 ;;
    --format) FORMAT="${2:-text}"; shift 2 ;;
    *) echo "error: unknown option: $1" >&2; exit 64 ;;
  esac
done

# Compute since timestamp.
if [[ -z "$SINCE_ISO" ]]; then
  case "$LAST_WINDOW" in
    *h) hours="${LAST_WINDOW%h}"; SINCE_ISO=$(date -u -d "$hours hours ago" +%Y-%m-%dT%H:%M:%SZ) ;;
    *d) days="${LAST_WINDOW%d}";  SINCE_ISO=$(date -u -d "$days days ago"  +%Y-%m-%dT%H:%M:%SZ) ;;
    *)  echo "error: --last must be Nh or Nd (e.g. 24h, 7d)" >&2; exit 64 ;;
  esac
fi

if [[ ! -f "$LOG_FILE" || ! -s "$LOG_FILE" ]]; then
  echo "No telemetry yet at $LOG_FILE — fire a glm-subagent dispatch to generate data."
  exit 0
fi

# Filter once, reuse across formats.
FILTERED=$(jq -c --arg since "$SINCE_ISO" --arg cwd "$CWD_FILTER" '
  select(.ts >= $since) | select($cwd == "" or (.cwd | contains($cwd)))
' "$LOG_FILE")

if [[ -z "$FILTERED" ]]; then
  echo "No telemetry in window since $SINCE_ISO${CWD_FILTER:+ (cwd filter: $CWD_FILTER)}."
  exit 0
fi

# Helper jq filter — compute real GLM $ cost from token counts.
# Token fields are null on v0.1 entries; treat null as 0 to avoid skew.
COST_FILTER='
def n(x): if (x == null or x == "null") then 0 else x end;
{
  input_tokens:        n(.prompt_tokens),
  output_tokens:       n(.completion_tokens),
  cache_read_tokens:   n(.cache_read_tokens),
  cache_create_tokens: n(.cache_creation_tokens),
  cli_cost:            n(.cli_cost_usd_claude_rate),
  real_cost:           (
    n(.prompt_tokens)           * ('"$GLM_INPUT_USD_PER_M"'       / 1000000) +
    n(.completion_tokens)       * ('"$GLM_OUTPUT_USD_PER_M"'      / 1000000) +
    n(.cache_read_tokens)       * ('"$GLM_CACHE_READ_USD_PER_M"'  / 1000000) +
    n(.cache_creation_tokens)   * ('"$GLM_CACHE_WRITE_USD_PER_M"' / 1000000)
  )
}
'

case "$FORMAT" in
  json)
    printf '%s\n' "$FILTERED"
    ;;

  csv)
    echo "ts,uuid,cwd,model,packet_bytes,response_bytes,wall_clock_ms,exit_code,prompt_tokens,completion_tokens,total_tokens,cache_read_tokens,cli_cost_usd_claude_rate"
    printf '%s\n' "$FILTERED" | jq -r '[
      .ts,.uuid,.cwd,.model,.packet_bytes,.response_bytes,.wall_clock_ms,.exit_code,
      (.prompt_tokens // ""),(.completion_tokens // ""),(.total_tokens // ""),
      (.cache_read_tokens // ""),(.cli_cost_usd_claude_rate // "")
    ] | @csv'
    ;;

  table)
    printf '%-50s %6s %7s %9s %10s %10s %10s %12s\n' \
      "cwd" "calls" "errors" "avg_ms" "tok_in" "tok_out" "tok_cache" "\$_glm_real"
    printf '%-50s %6s %7s %9s %10s %10s %10s %12s\n' \
      "---" "---" "---" "---" "---" "---" "---" "---"
    printf '%s\n' "$FILTERED" | jq -s -r --argjson in_rate "$GLM_INPUT_USD_PER_M" \
                                          --argjson out_rate "$GLM_OUTPUT_USD_PER_M" \
                                          --argjson cr_rate "$GLM_CACHE_READ_USD_PER_M" \
                                          --argjson cw_rate "$GLM_CACHE_WRITE_USD_PER_M" '
      def n(x): if (x == null or x == "null") then 0 else x end;
      group_by(.cwd) | .[] | (
        ((map(n(.prompt_tokens))         | add) * ($in_rate  / 1000000) +
         (map(n(.completion_tokens))     | add) * ($out_rate / 1000000) +
         (map(n(.cache_read_tokens))     | add) * ($cr_rate  / 1000000) +
         (map(n(.cache_creation_tokens)) | add) * ($cw_rate  / 1000000)) as $real |
        [
          .[0].cwd,
          length,
          ([.[] | select(.exit_code != 0)] | length),
          ((map(.wall_clock_ms) | add) / length | floor),
          (map(n(.prompt_tokens))     | add),
          (map(n(.completion_tokens)) | add),
          (map(n(.cache_read_tokens)) | add),
          (($real * 10000 | floor) / 10000)
        ]
      ) | @tsv
    ' | awk -F'\t' '{printf "%-50s %6s %7s %9s %10s %10s %10s %12s\n", $1, $2, $3, $4, $5, $6, $7, "$"$8}'
    ;;

  cost)
    # Per-cwd $ breakdown: GLM real cost vs CLI Claude-rate cost.
    printf '%-50s %6s %14s %14s %8s\n' \
      "cwd" "calls" "\$_glm_real" "\$_claude_rate" "ratio"
    printf '%-50s %6s %14s %14s %8s\n' \
      "---" "---" "---" "---" "---"
    printf '%s\n' "$FILTERED" | jq -s -r --argjson in_rate "$GLM_INPUT_USD_PER_M" \
                                          --argjson out_rate "$GLM_OUTPUT_USD_PER_M" \
                                          --argjson cr_rate "$GLM_CACHE_READ_USD_PER_M" \
                                          --argjson cw_rate "$GLM_CACHE_WRITE_USD_PER_M" '
      def n(x): if (x == null or x == "null") then 0 else x end;
      group_by(.cwd) | .[] | (
        ((map(n(.prompt_tokens))           | add) * ($in_rate  / 1000000) +
         (map(n(.completion_tokens))       | add) * ($out_rate / 1000000) +
         (map(n(.cache_read_tokens))       | add) * ($cr_rate  / 1000000) +
         (map(n(.cache_creation_tokens))   | add) * ($cw_rate  / 1000000)) as $real |
        ((map(n(.cli_cost_usd_claude_rate)) | add)) as $cli |
        [
          .[0].cwd,
          length,
          ($real * 10000 | floor) / 10000,
          ($cli  * 10000 | floor) / 10000,
          (if $real > 0 then (($cli / $real) * 100 | floor) / 100 else 0 end)
        ]
      ) | @tsv
    ' | awk -F'\t' '{printf "%-50s %6s %14s %14s %8s\n", $1, $2, "$"$3, "$"$4, $5"x"}'
    ;;

  text|*)
    SUMMARY=$(printf '%s\n' "$FILTERED" | jq -s --argjson in_rate "$GLM_INPUT_USD_PER_M" \
                                                 --argjson out_rate "$GLM_OUTPUT_USD_PER_M" \
                                                 --argjson cr_rate "$GLM_CACHE_READ_USD_PER_M" \
                                                 --argjson cw_rate "$GLM_CACHE_WRITE_USD_PER_M" \
                                                 --arg since "$SINCE_ISO" '
      def n(x): if (x == null or x == "null") then 0 else x end;
      {
        since: $since,
        calls: length,
        errors: ([.[] | select(.exit_code != 0)] | length),
        avg_wall_ms: (if length > 0 then ((map(.wall_clock_ms) | add) / length | floor) else 0 end),
        bytes_in: (map(.packet_bytes) | add),
        bytes_out: (map(.response_bytes) | add),
        tokens_in:        (map(n(.prompt_tokens))         | add),
        tokens_out:       (map(n(.completion_tokens))     | add),
        tokens_cache_r:   (map(n(.cache_read_tokens))     | add),
        tokens_cache_w:   (map(n(.cache_creation_tokens)) | add),
        cost_glm_real_usd: (
          ((
            (map(n(.prompt_tokens))         | add) * ($in_rate  / 1000000) +
            (map(n(.completion_tokens))     | add) * ($out_rate / 1000000) +
            (map(n(.cache_read_tokens))     | add) * ($cr_rate  / 1000000) +
            (map(n(.cache_creation_tokens)) | add) * ($cw_rate  / 1000000)
          ) * 10000 | floor) / 10000
        ),
        cost_cli_claude_rate_usd: (((map(n(.cli_cost_usd_claude_rate)) | add) * 10000 | floor) / 10000)
      }
    ')

    echo "$SUMMARY" | jq -r '
      "glm-usage since \(.since)",
      "  \(.calls) calls, \(.errors) errors, \(.avg_wall_ms) ms avg wall-clock",
      "  packet bytes: \(.bytes_in) in / \(.bytes_out) out",
      "  tokens:       \(.tokens_in) in / \(.tokens_out) out / \(.tokens_cache_r) cache-read / \(.tokens_cache_w) cache-write",
      "  cost (GLM real):    $\(.cost_glm_real_usd)",
      "  cost (claude-rate): $\(.cost_cli_claude_rate_usd) (CLI estimate at Anthropic rates — reference only)"
    '
    ;;
esac
